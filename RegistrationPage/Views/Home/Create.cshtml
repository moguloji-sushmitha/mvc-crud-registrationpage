@model List<RegistrationPage.Models.Registration>
@{
    Layout = null;
}
<style>
    body {
        margin: 0;
        background-color: #bec8f3;
        font-family: Arial;
    }
    .container{
        height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
    }
    .card {
        background-color: #ffffff;
        box-shadow: 0px 0px 10px grey;
        align-items: center;
        width: 300px;
        border-radius:10px;
        padding:25px;
    }
    h2{
        text-align:center
    }
    label{
        display:block;
        margin-top:8px;
    }
    input{
        padding:10px;
        width:100%;
        margin-top:8px;
    }
    button{
        width:100%;
        color:#ffffff;
        background-color:#9799fa;
        margin-top:8px;
        cursor:pointer;
        padding:10px;
    }
    table{
        display:flex;
        text-align:center;
        justify-content:center;
    }

</style>
<div class="container">
    <div class="card">
        <h2>Registration Page</h2>
    <form method="post" action="/Home/Create">
        <label>Id</label>
        <input type="text" name="Id" /><br />
        <label>Name</label>
        <input type="text" name="Name" /><br />
        <label>Mail</label>
        <input type="text" name="Email" /><br />
        <button type="submit">Save</button>
    </form>
</div>
</div>

<h2>All Users</h2>
<table border="1">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Email</th>
        <th>Action</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>

            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Email</td>
            <td>
                <a href="@Url.Action("Edit", "Home", new {id=item.Id})">Edit</a>
                <a href="@Url.Action("Delete", "Home", new {id=item.Id})">Delete</a>
            </td>
        </tr>
    }
</table>




